# =====================================
# PERSONA AI SYSTEM - CONFIGURATION
# =====================================
# Instructions:
# 1. Copy this file and rename to: .env
# 2. Replace 'your-openai-api-key-here' with your actual API key
# 3. Save the file and start the application

# ===== REQUIRED (Must Update) =====

# OpenAI API Key - Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Alternative AI Providers (optional)
# Anthropic Claude API Key - Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Google Gemini API Key - Get yours at: https://makersuite.google.com/app/apikey  
GEMINI_API_KEY=your-gemini-api-key-here

# ===== BASIC SETTINGS (Usually OK as-is) =====

# Server Configuration
API_HOST=localhost
API_PORT=8000
DEBUG=True
ENVIRONMENT=development

# Frontend URL (where the web interface is served)
FRONTEND_URL=http://localhost:8000

# ===== OPTIONAL SETTINGS (Defaults work fine) =====

# LLM Provider Selection (optimized for latency)
# LLM_PROVIDER=openai     # For GPT-4.1-nano (fastest first token)
# LLM_PROVIDER=gemini     # For Gemini 2.5 Flash Lite (best per-token)
# LLM_PROVIDER=anthropic  # For Claude fallbacks
LLM_PROVIDER=gemini

# Alternative AI Provider (optional)
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Model Configuration (latency optimized)
# DEFAULT_MODEL=gpt-4.1-nano         # Fastest time to first token (for analysis)
# DEFAULT_MODEL=gemini-2.5-flash-lite-001  # Best per-token latency (for personas)
# DEFAULT_MODEL=claude-3-haiku       # Fast balanced option
DEFAULT_MODEL=gemini-2.5-flash-lite-001  # Recommended for production
EMBEDDING_MODEL=text-embedding-ada-002
MAX_TOKENS=2000
TEMPERATURE=0.7

# Logging Level
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR

# ===== SUPABASE CONFIGURATION (NEW - For Vector Storage) =====

# Get these from your Supabase project settings
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here  # Optional, for client access

# ===== ADVANCED SETTINGS (For Production) =====

# Database Configuration (uses SQLite by default)
# DATABASE_URL=sqlite:///./persona_ai.db
# For PostgreSQL (advanced users):
# DATABASE_URL=postgresql://user:password@localhost:5432/persona_db

# Redis Cache (optional - for better performance)
# REDIS_URL=redis://localhost:6379

# Legacy ChromaDB settings (DEPRECATED - Remove if using Supabase)
# CHROMA_HOST=localhost
# CHROMA_PORT=8000

# Security (auto-generated if not provided)
# SECRET_KEY=your-secret-key-here
# JWT_SECRET_KEY=your-jwt-secret-key
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# Error Monitoring (optional)
# SENTRY_DSN=your-sentry-dsn-here

# Metrics (optional)
# PROMETHEUS_PORT=8001

# ===== TROUBLESHOOTING =====
# 
# If you see "API key not found":
#   - Make sure you copied this file to .env (not .env.example)
#   - Check that your API key starts with 'sk-'
#   - Remove any extra spaces or quotes around the key
#
# If you see "Port already in use":
#   - Change API_PORT to 8001 or another number
#   - Also update FRONTEND_URL to match (e.g., http://localhost:8001)
